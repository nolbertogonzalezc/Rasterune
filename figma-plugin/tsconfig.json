{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "lib": ["ES2020", "DOM"],
    "types": ["@figma/plugin-typings"],
    "skipLibCheck": true,
    "noEmit": true
  },
  "include": [
    "src",
    "../src/engine/**/*.ts",
    "../src/shared/utils/filename.ts",
    "../src/shared/state/types.ts"
  ]
}
